"dare",level:"extreme",text:"Kiss your partner while both standing \u2014 lift or dip them if you can.",followUp:"Hold the position as long as possible."},{id:"tod_113",type:"truth",level:"extreme",text:"What is the most vulnerable you have ever felt during intimacy, and did it feel good?",followUp:"How can you create that safety again?"},{id:"tod_114",type:"dare",level:"extreme",text:"Whisper a play-by-play of everything you plan to do tonight.",followUp:"Follow through on at least one thing."},{id:"tod_115",type:"truth",level:"extreme",text:"What is the one thing that would make you completely lose control in the best way?",followUp:"Has your partner ever gotten close to triggering it?"},{id:"tod_116",type:"dare",level:"extreme",text:"Choose a body part \u2014 your partner has 60 seconds to make that spot feel incredible.",followUp:"Give real-time feedback."},{id:"tod_117",type:"truth",level:"extreme",text:"Describe your dream intimate getaway \u2014 location, mood, setting, everything.",followUp:"Start planning it seriously."},{id:"tod_118",type:"dare",level:"extreme",text:"Turn off all lights, lie together, and communicate only through touch for three minutes.",followUp:"See where it leads naturally."},{id:"tod_119",type:"truth",level:"extreme",text:"What is one intimate experience that left you completely breathless?",followUp:"What elements can you bring into tonight?"},{id:"tod_120",type:"dare",level:"extreme",text:"End this game right now and act on the most exciting thing discussed tonight.",followUp:"No more talking \u2014 just action."}]},1174,[]);
__d(function(e,o,i,t,n,r,s){n.exports=[{id:"wyr_001",level:"mild",optionA:"Always know what your partner is thinking",optionB:"Have your partner always know what you're thinking",discussionPrompt:"How do you feel about emotional transparency in your relationship?"},{id:"wyr_002",level:"mild",optionA:"Relive your first date forever",optionB:"Fast-forward to your 50th anniversary",discussionPrompt:"What do you value more \u2014 new beginnings or lasting commitment?"},{id:"wyr_003",level:"mild",optionA:"Never argue again but lose some passion",optionB:"Argue sometimes but keep all the passion",discussionPrompt:"How do you feel conflict and passion are connected?"},{id:"wyr_004",level:"mild",optionA:"Travel the world together for a year",optionB:"Build your dream home together",discussionPrompt:"Are you more adventure-oriented or nesting-oriented as a couple?"},{id:"wyr_005",level:"mild",optionA:"Have your partner cook for you every day",optionB:"Have your partner plan a surprise date every month",discussionPrompt:"Which love language speaks louder \u2014 acts of service or quality time?"},{id:"wyr_006",level:"mild",optionA:"Be able to read your partner's mood perfectly",optionB:"Have your partner always say exactly what they need",discussionPrompt:"Which matters more \u2014 intuition or communication?"},{id:"wyr_007",level:"mild",optionA:"Spend every evening cuddling on the couch",optionB:"Go on a new adventure every weekend",discussionPrompt:"How do you balance comfort and excitement?"},{id:"wyr_008",level:"mild",optionA:"Have your partner write you a love letter every week",optionB:"Receive a surprise gift once a month",discussionPrompt:"Words or actions \u2014 which moves you more?"},{id:"wyr_009",level:"mild",optionA:"Always laugh together",optionB:"Always cry together",discussionPrompt:"Which form of emotional connection feels deeper?"},{id:"wyr_010",level:"mild",optionA:"Know everything about your partner's past",optionB:"Know everything about your partner's dreams for the future",discussionPrompt:"Does the past or future matter more in a relationship?"},{id:"wyr_011",level:"mild",optionA:"Be the funny one in the relationship",optionB:"Be the romantic one",discussionPrompt:"Which role do you naturally lean toward?"},{id:"wyr_012",level:"mild",optionA:"Have a partner who surprises you constantly",optionB:"Have a partner who is completely predictable and reliable",discussionPrompt:"How much spontaneity do you need?"},{id:"wyr_013",level:"mild",optionA:"Live in a tiny apartment in your dream city",optionB:"Live in a mansion in a boring town",discussionPrompt:"What matters more \u2014 location or space?"},{id:"wyr_014",level:"mild",optionA:"Have perfect communication",optionB:"Have perfect chemistry",discussionPrompt:"Can one exist without the other?"},{id:"wyr_015",level:"mild",optionA:"Grow old looking young",optionB:"Grow old feeling young",discussionPrompt:"How important is physical appearance vs vitality?"},{id:"wyr_016",level:"mild",optionA:"Always fall asleep together",optionB:"Always wake up together",discussionPrompt:"Which bookend of the day matters more?"},{id:"wyr_017",level:"mild",optionA:"Have matching tattoos",optionB:"Have matching bucket lists",discussionPrompt:"Permanent symbols or shared experiences?"},{id:"wyr_018",level:"mild",optionA:"Your partner remembers every detail you share",optionB:"Your partner always knows how to cheer you up",discussionPrompt:"Memory or emotional intelligence?"},{id:"wyr_019",level:"mild",optionA:"Have a couple's hobby you both love",optionB:"Have completely separate hobbies that give you space",discussionPrompt:"How much togetherness is ideal?"},{id:"wyr_020",level:"mild",optionA:"Renew your vows every year",optionB:"Go on a second honeymoon every year",discussionPrompt:"Symbolic gestures or shared experiences?"},{id:"wyr_021",level:"medium",optionA:"Have an incredibly passionate but short relationship",optionB:"Have a calm and steady lifelong partnership",discussionPrompt:"What does sustainable passion look like to you?"},{id:"wyr_022",level:"medium",optionA:"Your partner gives the best massages",optionB:"Your partner gives the best compliments",discussionPrompt:"Physical touch or words of affirmation?"},{id:"wyr_023",level:"medium",optionA:"Be completely spontaneous in the bedroom",optionB:"Plan every intimate encounter in advance",discussionPrompt:"Does anticipation enhance or diminish excitement?"},{id:"wyr_024",level:"medium",optionA:"Have one mind-blowing date night a month",optionB:"Have a sweet daily ritual together",discussionPrompt:"Intensity vs consistency?"},{id:"wyr_025",level:"medium",optionA:"Your partner initiates intimacy more often",optionB:"You feel more confident initiating yourself",discussionPrompt:"How do you feel about initiation dynamics?"},{id:"wyr_026",level:"medium",optionA:"Always set the mood perfectly before intimacy",optionB:"Be spontaneous and skip the buildup",discussionPrompt:"How important is ambiance to you?"},{id:"wyr_027",level:"medium",optionA:"Have a partner who is an amazing kisser",optionB:"Have a partner who is an amazing cuddler",discussionPrompt:"Which form of physical affection do you crave more?"},{id:"wyr_028",level:"medium",optionA:"Receive a steamy love letter",optionB:"Receive a surprise romantic setup at home",discussionPrompt:"Words or gestures?"},{id:"wyr_029",level:"medium",optionA:"Have a slow, romantic evening",optionB:"Have a fast, passionate encounter",discussionPrompt:"When does each feel more appropriate?"},{id:"wyr_030",level:"medium",optionA:"Be the one who teases",optionB:"Be the one who gets teased",discussionPrompt:"Which builds more anticipation for you?"},{id:"wyr_031",level:"medium",optionA:"Your partner always tells you what feels good",optionB:"You can always read your partner's body language perfectly",discussionPrompt:"Verbal or nonverbal communication during intimacy?"},{id:"wyr_032",level:"medium",optionA:"Have longer foreplay and shorter main event",optionB:"Skip foreplay and have a longer main event",discussionPrompt:"How important is the buildup?"},{id:"wyr_033",level:"medium",optionA:"Try something new every time",optionB:"Perfect the things you already love",discussionPrompt:"Novelty vs mastery?"},{id:"wyr_034",level:"medium",optionA:"Your partner plans a surprise romantic weekend",optionB:"You both plan the perfect romantic weekend together",discussionPrompt:"Surprise or collaboration?"},{id:"wyr_035",level:"medium",optionA:"Have a deep emotional connection before physical",optionB:"Let physical connection deepen emotional bonds",discussionPrompt:"Which comes first for you?"},{id:"wyr_036",level:"medium",optionA:"Be told exactly what your partner wants",optionB:"Discover what your partner wants through exploration",discussionPrompt:"Directness or discovery?"},{id:"wyr_037",level:"medium",optionA:"Have incredible morning intimacy",optionB:"Have incredible late-night intimacy",discussionPrompt:"When are you at your most connected?"},{id:"wyr_038",level:"medium",optionA:"Your partner sends you flirty texts all day",optionB:"Your partner saves all the flirting for when you are together",discussionPrompt:"Anticipation throughout the day or concentrated attention?"},{id:"wyr_039",level:"medium",optionA:"Never have an awkward intimate moment again",optionB:"Always be able to laugh through awkward moments",discussionPrompt:"How do you handle imperfection in intimacy?"},{id:"wyr_040",level:"medium",optionA:"Have a partner who is bold and takes charge",optionB:"Have a partner who is attentive and follows your lead",discussionPrompt:"Does your preference change depending on mood?"},{id:"wyr_041",level:"spicy",optionA:"Try a new intimate position every week for a year",optionB:"Master one position until it is absolutely perfect",discussionPrompt:"Variety or expertise?"},{id:"wyr_042",level:"spicy",optionA:"Have a partner who talks passionately during intimacy",optionB:"Have a partner who is intensely silent and focused",discussionPrompt:"Sound or silence?"},{id:"wyr_043",level:"spicy",optionA:"Spend an entire day in bed together",optionB:"Have one hour of the most intense connection possible",discussionPrompt:"Duration or intensity?"},{id:"wyr_044",level:"spicy",optionA:"Always be in control during intimacy",optionB:"Always let your partner take control",discussionPrompt:"How do power dynamics affect your enjoyment?"},{id:"wyr_045",level:"spicy",optionA:"Use blindfolds and sensory play",optionB:"Use music and lighting to set the mood",discussionPrompt:"Removing senses or enhancing them?"},{id:"wyr_046",level:"spicy",optionA:"Be intimate somewhere exciting but risky",optionB:"Be intimate in the most comfortable setting imaginable",discussionPrompt:"Thrill vs comfort?"},{id:"wyr_047",level:"spicy",optionA:"Your partner learns every single thing about your body",optionB:"There is always something new for your partner to discover",discussionPrompt:"Complete knowledge or eternal mystery?"},{id:"wyr_048",level:"spicy",optionA:"Have an incredibly passionate quickie",optionB:"Have a slow, all-night session",discussionPrompt:"When does each feel more satisfying?"},{id:"wyr_049",level:"spicy",optionA:"Be the one who initiates 90% of the time",optionB:"Be surprised by your partner initiating 90% of the time",discussionPrompt:"How does initiation frequency affect desire?"},{id:"wyr_050",level:"spicy",optionA:"Have the best foreplay imaginable",optionB:"Have the best aftercare and cuddling imaginable",discussionPrompt:"Beginning or ending of intimate moments?"},{id:"wyr_051",level:"spicy",optionA:"Try role-playing together",optionB:"Write intimate fantasies for each other to read",discussionPrompt:"Acting or imagining?"},{id:"wyr_052",level:"spicy",optionA:"Have a regular weekly date night that always ends passionately",optionB:"Have rare but incredibly spontaneous passionate moments",discussionPrompt:"Predictable passion or surprise fire?"},{id:"wyr_053",level:"spicy",optionA:"Use massage oils and candles every time",optionB:"Keep things raw and unplanned every time",discussionPrompt:"Prepared romance or primal connection?"},{id:"wyr_054",level:"spicy",optionA:"Watch something steamy together as inspiration",optionB:"Create your own inspiration from scratch",discussionPrompt:"External spark or internal chemistry?"},{id:"wyr_055",level:"spicy",optionA:"Be told in advance exactly what will happen tonight",optionB:"Have absolutely no idea what your partner has planned",discussionPrompt:"Anticipation with knowledge or suspense?"},{id:"wyr_056",level:"spicy",optionA:"Focus entirely on giving pleasure",optionB:"Focus entirely on receiving pleasure",discussionPrompt:"Which is harder for you?"},{id:"wyr_057",level:"spicy",optionA:"Have a safe word that unlocks a new level of trust",optionB:"Never need boundaries because you read each other perfectly",discussionPrompt:"Explicit safety or implicit understanding?"},{id:"wyr_058",level:"spicy",optionA:"Leave love marks on each other",optionB:"Leave love notes for each other to find later",discussionPrompt:"Physical or written reminders of passion?"},{id:"wyr_059",level:"spicy",optionA:"Have your partner undress you agonizingly slowly",optionB:"Have your partner undress you in two seconds flat",discussionPrompt:"Tension or urgency?"},{id:"wyr_060",level:"spicy",optionA:"Share every fantasy with your partner",optionB:"Keep some fantasies as your private thoughts",discussionPrompt:"Total openness or personal mystery?"},{id:"wyr_061",level:"extreme",optionA:"Act out your partner's deepest fantasy",optionB:"Have your partner act out yours",discussionPrompt:"Giving or receiving fulfillment?"},{id:"wyr_062",level:"extreme",optionA:"Be intimate in a completely new and unexpected location",optionB:"Transform your bedroom into an entirely new experience",discussionPrompt:"New place or new vibe?"},{id:"wyr_063",level:"extreme",optionA:"Have your partner tease you for hours before the main event",optionB:"Skip all teasing and go straight to the most intense moment",discussionPrompt:"Edging toward ecstasy or immediate intensity?"},{id:"wyr_064",level:"extreme",optionA:"Be blindfolded and trust your partner completely",optionB:"Blindfold your partner and have complete control",discussionPrompt:"Surrender or command?"},{id:"wyr_065",level:"extreme",optionA:"Have the stamina to last all night",optionB:"Have the intensity to make every second mind-blowing",discussionPrompt:"Marathon or sprint?"},{id:"wyr_066",level:"extreme",optionA:"Explore a completely new kink together",optionB:"Deepen an existing favorite to its ultimate level",discussionPrompt:"Breadth or depth of exploration?"},{id:"wyr_067",level:"extreme",optionA:"Your partner knows exactly what will make you finish",optionB:"Your partner keeps you on the edge as long as possible",discussionPrompt:"Satisfaction or suspense?"},{id:"wyr_068",level:"extreme",optionA:"Have a mirror facing the bed",optionB:"Record audio of your intimate moments to listen back",discussionPrompt:"Visual or auditory self-awareness?"},{id:"wyr_069",level:"extreme",optionA:"Only use your hands and mouth tonight",optionB:"Use anything in the room except your hands",discussionPrompt:"Restriction as creativity?"},{id:"wyr_070",level:"extreme",optionA:"Be woken up by your partner initiating intimacy",optionB:"Fall asleep during afterglow together",discussionPrompt:"Passionate awakening or blissful ending?"},{id:"wyr_071",level:"extreme",optionA:"Spend a weekend at a couples retreat focused on intimacy",optionB:"Create your own private retreat at home for a weekend",discussionPrompt:"Guided experience or self-directed?"},{id:"wyr_072",level:"extreme",optionA:"Your partner writes a detailed script for your evening together",optionB:"You improvise the entire night based on instinct",discussionPrompt:"Choreographed or freestyle?"},{id:"wyr_073",level:"extreme",optionA:"Communicate only through touch for an entire intimate session",optionB:"Communicate only through words \u2014 describing everything",discussionPrompt:"Which builds deeper connection?"},{id:"wyr_074",level:"extreme",optionA:"Have an intimate bucket list and check off one item tonight",optionB:"Let tonight be completely unplanned and see where instinct leads",discussionPrompt:"Goals or flow?"},{id:"wyr_075",level:"extreme",optionA:"Be praised and complimented throughout intimacy",optionB:"Be challenged and pushed to your limits",discussionPrompt:"Encouragement or intensity?"},{id:"wyr_076",level:"extreme",optionA:"Experience the most intense physical pleasure possible",optionB:"Experience the deepest emotional connection possible during intimacy",discussionPrompt:"Can you truly separate the two?"},{id:"wyr_077",level:"extreme",optionA:"Set a timer \u2014 everything must happen in 10 minutes",optionB:"No clock \u2014 go until you both naturally stop",discussionPrompt:"Pressure or freedom?"},{id:"wyr_078",level:"extreme",optionA:"Focus an entire session on one part of the body",optionB:"Explore every inch of each other in one session",discussionPrompt:"Deep focus or full exploration?"},{id:"wyr_079",level:"extreme",optionA:"Fulfill a fantasy your partner does not know you have",optionB:"Ask your partner to fulfill a fantasy they do not know you have",discussionPrompt:"Give the surprise or receive it?"},{id:"wyr_080",level:"extreme",optionA:"End every intimate session with honest feedback to each other",optionB:"Never discuss technique and just let things evolve naturally",discussionPrompt:"Growth through communication or through experience?"}]},1175,[]);
__d(function(e,t,o,i,n,a,s){n.exports={quizQuestions:[{id:"quiz_001",question:"Which hormone is often called the 'bonding hormone'?",options:["Cortisol","Oxytocin","Adrenaline","Serotonin"],correctIndex:1,explanation:"Oxytocin is released during physical touch, hugging, and intimacy. It strengthens emotional bonds between partners and promotes feelings of trust and attachment.",category:"health"},{id:"quiz_002",question:"What percentage of communication is nonverbal?",options:["25%","50%","70%","93%"],correctIndex:2,explanation:"Research suggests approximately 70-93% of communication is nonverbal. Body language, facial expressions, and tone of voice convey more than words alone \u2014 especially important during intimate moments.",category:"communication"},{id:"quiz_003",question:"According to Dr. John Gottman, what is the ideal ratio of positive to negative interactions in a healthy relationship?",options:["1:1","3:1","5:1","10:1"],correctIndex:2,explanation:"The 'magic ratio' is 5:1 \u2014 five positive interactions for every negative one. This applies to daily interactions, conflict resolution, and maintaining relationship satisfaction.",category:"psychology"},{id:"quiz_004",question:"How long does the average kiss last?",options:["2 seconds","6 seconds","12 seconds","20 seconds"],correctIndex:2,explanation:"Research shows the average kiss lasts about 12 seconds. Relationship experts suggest that kisses lasting at least 6 seconds help maintain connection and intimacy between partners.",category:"health"},{id:"quiz_005",question:"Which of these is NOT one of the five love languages identified by Dr. Gary Chapman?",options:["Physical Touch","Acts of Service","Financial Security","Quality Time"],correctIndex:2,explanation:"The five love languages are: Words of Affirmation, Acts of Service, Receiving Gifts, Quality Time, and Physical Touch. Understanding your partner's love language helps you express love in ways they receive best.",category:"psychology"},{id:"quiz_006",question:"What happens to your heart rate during a passionate kiss?",options:["It slows down","It stays the same","It can double","It becomes irregular"],correctIndex:2,explanation:"During a passionate kiss, your heart rate can increase from a resting 60-80 bpm to over 120 bpm. This cardiovascular boost is similar to light exercise and releases feel-good endorphins.",category:"health"},{id:"quiz_007",question:"What is the term for the early stage of a relationship characterized by intense attraction and euphoria?",options:["Attachment","Limerence","Companionship","Infatuation"],correctIndex:1,explanation:"Limerence is the psychological term for the intense, involuntary state of romantic attraction in early relationships. It typically lasts 18 months to 3 years before transitioning to deeper attachment.",category:"psychology"},{id:"quiz_008",question:"Which part of the body has the highest density of nerve endings?",options:["Fingertips","Lips","Neck","Earlobes"],correctIndex:0,explanation:"Fingertips have the highest density of nerve endings \u2014 about 2,500 per square centimeter. This is why hand-holding and gentle touch with fingertips can be incredibly intimate and stimulating.",category:"health"},{id:"quiz_009",question:"What is 'afterglow' in the context of intimacy?",options:["A skincare effect","Enhanced sexual satisfaction lasting up to 48 hours","The flush on your face","A type of candle"],correctIndex:1,explanation:"Research from Florida State University found that 'sexual afterglow' \u2014 heightened satisfaction after intimacy \u2014 lasts up to 48 hours and plays a key role in pair bonding and relationship satisfaction.",category:"psychology"},{id:"quiz_010",question:"How many muscles are used during a kiss?",options:["2","12","34","72"],correctIndex:2,explanation:"A passionate kiss engages 34 facial muscles and 112 postural muscles. The orbicularis oris muscle (the main kissing muscle) is the most important, controlling lip movement and pressure.",category:"health"},{id:"quiz_011",question:"What is the most effective way to resolve conflict in a relationship?",options:["Avoid the topic entirely","Win the argument at all costs","Use 'I' statements and active listening","Give the silent treatment"],correctIndex:2,explanation:"Using 'I' statements (e.g., 'I feel hurt when...') combined with active listening prevents defensiveness and promotes understanding. This approach validates both partners' feelings.",category:"communication"},{id:"quiz_012",question:"Which neurotransmitter is most associated with the excitement of new love?",options:["GABA","Dopamine","Acetylcholine","Glutamate"],correctIndex:1,explanation:"Dopamine floods the brain during new love, creating feelings of euphoria, motivation, and reward \u2014 similar to the effect of certain stimulants. This is why new love feels so exciting and addictive.",category:"health"},{id:"quiz_013",question:"What is 'responsive desire' in sexual psychology?",options:["Wanting intimacy only in response to a partner's request","Desire that arises after physical arousal has begun","A condition that requires treatment","Desire that responds to medication"],correctIndex:1,explanation:"Responsive desire means arousal and desire emerge AFTER physical intimacy begins, rather than before. This is completely normal and affects about 30% of women and some men. Understanding this prevents misinterpreting lower spontaneous desire.",category:"psychology"},{id:"quiz_014",question:"How long does it take for physical touch to trigger oxytocin release?",options:["Instantly","About 20 seconds","5 minutes","30 minutes"],correctIndex:1,explanation:"Research shows that sustained physical touch for about 20 seconds triggers significant oxytocin release. This is why longer hugs (20+ seconds) feel more connecting than quick ones.",category:"health"},{id:"quiz_015",question:"What is 'bid for connection' in relationship psychology?",options:["Proposing marriage","Any attempt to get your partner's attention or affection","Asking for a date","A negotiation technique"],correctIndex:1,explanation:"Gottman's research found that 'bids for connection' are small moments where one partner reaches out for attention, affection, or support. Couples who 'turn toward' bids 86% of the time stay together; those at 33% divorce.",category:"communication"},{id:"quiz_016",question:"What effect does laughter have on intimacy?",options:["It kills the mood","It releases endorphins and deepens connection","It has no effect","It only helps if both people laugh"],correctIndex:1,explanation:"Shared laughter releases endorphins, reduces cortisol (stress hormone), and creates positive associations between partners. Couples who laugh together report higher relationship satisfaction and better intimate lives.",category:"psychology"},{id:"quiz_017",question:"What is the average duration of foreplay that most people find satisfying?",options:["2-3 minutes","5-7 minutes","13-18 minutes","30+ minutes"],correctIndex:2,explanation:"Studies show that most people find 13-18 minutes of foreplay ideal for satisfaction. However, individual preferences vary greatly, and communication about what feels right is more important than any number.",category:"health"},{id:"quiz_018",question:"Which sense is most strongly linked to memory and emotion?",options:["Sight","Hearing","Smell","Touch"],correctIndex:2,explanation:"The olfactory system (smell) connects directly to the limbic system, which processes emotions and memories. This is why certain scents can instantly transport you back to intimate moments with your partner.",category:"psychology"},{id:"quiz_019",question:"What is 'skin hunger'?",options:["A skin condition","The biological need for physical touch","Itchy skin from allergies","A diet-related condition"],correctIndex:1,explanation:"Skin hunger (or touch deprivation) is the biological and emotional need for physical touch. Humans require regular physical contact for emotional wellbeing \u2014 lack of it can lead to increased stress, anxiety, and feelings of isolation.",category:"health"},{id:"quiz_020",question:"According to research, what time of day do most couples feel most connected?",options:["Morning","Lunchtime","Evening after work","Late at night"],correctIndex:2,explanation:"Research shows couples feel most emotionally connected during the 'reunion' period after work/daily separation. How you greet each other and the first 20 minutes together set the emotional tone for the rest of the evening.",category:"communication"},{id:"quiz_021",question:"What is the 'Coolidge Effect'?",options:["Desire increases with familiarity","Novel partners trigger renewed arousal","Cold temperatures increase libido","A cooling-off period after conflict"],correctIndex:1,explanation:"The Coolidge Effect describes how novel stimuli can renew sexual interest. In long-term relationships, this means introducing novelty (new experiences, settings, or activities) can reignite passion.",category:"psychology"},{id:"quiz_022",question:"How does regular physical intimacy affect the immune system?",options:["Weakens it","No effect","Boosts immunoglobulin A levels","Only helps during winter"],correctIndex:2,explanation:"Research from Wilkes University found that people who are intimate 1-2 times per week have 30% higher levels of immunoglobulin A (IgA), an antibody that helps fight infections.",category:"health"},{id:"quiz_023",question:"What is 'emotional flooding' during an argument?",options:["Crying excessively","Heart rate exceeding 100 bpm making rational discussion impossible","Sharing too many emotions at once","A therapeutic technique"],correctIndex:1,explanation:"Emotional flooding occurs when stress hormones spike and heart rate exceeds 100 bpm during conflict. At this point, rational discussion becomes physiologically impossible. Taking a 20-minute break allows the body to reset.",category:"communication"},{id:"quiz_024",question:"What role does vulnerability play in intimacy?",options:["It should be avoided","It creates deeper connection and trust","It is only for new relationships","It weakens the relationship"],correctIndex:1,explanation:"Bren\xe9 Brown's research shows vulnerability is the birthplace of intimacy, connection, and belonging. Allowing yourself to be truly seen by your partner \u2014 emotionally and physically \u2014 builds the deepest form of trust.",category:"psychology"},{id:"quiz_025",question:"What is the primary benefit of maintaining eye contact during intimacy?",options:["It is considered polite","It triggers oxytocin release and deepens connection","It helps with balance","There is no proven benefit"],correctIndex:1,explanation:"Sustained eye contact during intimacy triggers oxytocin release, activates the brain's reward centers, and creates a feedback loop of connection. Even 2-4 minutes of eye gazing can significantly increase feelings of closeness.",category:"health"},{id:"quiz_026",question:"How does physical exercise affect intimate desire?",options:["Decreases it from fatigue","Has no connection","Increases testosterone, blood flow, and body confidence","Only matters for athletes"],correctIndex:2,explanation:"Regular exercise increases testosterone levels, improves blood circulation, boosts endorphins, and enhances body confidence \u2014 all of which contribute to healthier desire and more satisfying intimate experiences.",category:"health"},{id:"quiz_027",question:"What does the '4 Horsemen' concept refer to in relationship research?",options:["Four stages of love","Four types of attachment","Four destructive communication patterns","Four types of intimacy"],correctIndex:2,explanation:"Gottman's 'Four Horsemen' are criticism, contempt, defensiveness, and stonewalling \u2014 four communication patterns that predict relationship failure with 93% accuracy. Recognizing and replacing them is crucial.",category:"communication"},{id:"quiz_028",question:"What is 'erotic intelligence'?",options:["IQ related to romance","The ability to maintain desire in long-term relationships","Knowledge of anatomy","A personality type"],correctIndex:1,explanation:"Esther Perel coined 'erotic intelligence' to describe the skill of maintaining desire, mystery, and passion within committed relationships. It involves balancing security with novelty and comfort with excitement.",category:"psychology"},{id:"quiz_029",question:"How does stress affect intimate desire?",options:["It increases desire as a coping mechanism","Cortisol suppresses sex hormones, reducing desire","It has no effect","It only affects men"],correctIndex:1,explanation:"Chronic stress elevates cortisol, which directly suppresses testosterone and estrogen production \u2014 reducing desire in both partners. Stress management (exercise, meditation, communication) is essential for a healthy intimate life.",category:"health"},{id:"quiz_030",question:"What is 'attachment style' and why does it matter for intimacy?",options:["How you physically hold your partner","Your childhood bonding patterns that shape adult relationships","A fashion preference","Only relevant in therapy"],correctIndex:1,explanation:"Attachment styles (secure, anxious, avoidant, disorganized) form in childhood and profoundly influence how we connect in adult relationships. Understanding your and your partner's attachment style helps navigate intimacy challenges.",category:"psychology"},{id:"quiz_031",question:"What is the benefit of pillow talk (post-intimacy conversation)?",options:["It is just small talk","Oxytocin peaks make it ideal for deep bonding","It helps you fall asleep","There is no research on this"],correctIndex:1,explanation:"Post-intimacy, oxytocin levels are at their peak, creating an ideal window for emotional bonding. Research shows that couples who engage in affectionate post-intimacy communication report higher relationship satisfaction.",category:"communication"},{id:"quiz_032",question:"How does sleep quality affect intimate desire?",options:["No connection","Each extra hour of sleep increases desire by 14%","Only REM sleep matters","Less sleep increases desire"],correctIndex:1,explanation:"A University of Michigan study found that each additional hour of sleep increased the likelihood of intimate activity with a partner by 14%. Quality sleep regulates hormones critical for desire and arousal.",category:"health"},{id:"quiz_033",question:"What is 'sensate focus' technique?",options:["A meditation practice","Structured touching exercises to reduce performance anxiety","A type of massage","A breathing exercise"],correctIndex:1,explanation:"Developed by Masters and Johnson, sensate focus involves structured, non-goal-oriented touching exercises that help couples reconnect physically, reduce performance anxiety, and rediscover pleasure without pressure.",category:"psychology"},{id:"quiz_034",question:"Why is consent considered ongoing rather than one-time?",options:["Legal requirement only","Because desires and boundaries can change at any moment","It is just a formality","Only in new relationships"],correctIndex:1,explanation:"Consent is continuous because comfort levels, desires, and boundaries can change at any moment \u2014 even during intimacy. Checking in with your partner shows respect, builds trust, and actually enhances the experience.",category:"communication"},{id:"quiz_035",question:"What effect does gratitude have on relationship satisfaction?",options:["Minimal effect","Expressing gratitude increases relationship satisfaction by up to 25%","Only works if reciprocated","It can make partners complacent"],correctIndex:1,explanation:"Research shows that regularly expressing gratitude to your partner increases relationship satisfaction by up to 25%. It creates positive feedback loops, increases feelings of being valued, and strengthens emotional bonds.",category:"psychology"},{id:"quiz_036",question:"What is the 'dual control model' of sexual response?",options:["Two people controlling the experience equally","Separate 'accelerator' and 'brake' systems in the brain","A technique for simultaneous pleasure","A couples therapy approach"],correctIndex:1,explanation:"The dual control model explains that everyone has a sexual 'accelerator' (excitation system) and 'brake' (inhibition system). Understanding what activates each in you and your partner is key to satisfying intimate experiences.",category:"health"},{id:"quiz_037",question:"How does novelty affect long-term relationship desire?",options:["It has no effect after the first year","New experiences together activate the same brain regions as early romance","Novelty is only for dating","It creates instability"],correctIndex:1,explanation:"New shared experiences activate dopamine pathways similar to early romance. Couples who regularly try new things together \u2014 whether travel, hobbies, or intimate exploration \u2014 report higher desire and satisfaction.",category:"psychology"},{id:"quiz_038",question:"What is 'responsive communication' in the bedroom?",options:["Responding quickly to texts","Verbally and nonverbally reacting to your partner's pleasure","Saying yes to everything","Communicating after intimacy only"],correctIndex:1,explanation:"Responsive communication means actively showing your partner \u2014 through sounds, words, touch, and body language \u2014 what feels good and how their actions affect you. It creates a feedback loop that enhances pleasure for both.",category:"communication"},{id:"quiz_039",question:"How many calories does a 30-minute intimate session burn on average?",options:["20-30","50-80","85-150","200-300"],correctIndex:2,explanation:"Research published in PLOS ONE found that an average 30-minute intimate session burns 85-150 calories \u2014 comparable to a brisk walk. Heart rate, muscle engagement, and intensity all contribute to the calorie burn.",category:"health"},{id:"quiz_040",question:"What does research say about couples who maintain a sense of humor together?",options:["They argue more often","They have 67% higher relationship satisfaction","Humor has no measurable impact","It only matters in the first year"],correctIndex:1,explanation:"Studies show couples who share humor and laugh together regularly report up to 67% higher relationship satisfaction. Shared laughter reduces stress, creates positive memories, and builds resilience during difficult times.",category:"psychology"}],diceActions:[{id:"act_01",text:"Kiss"},{id:"act_02",text:"Massage"},{id:"act_03",text:"Whisper to"},{id:"act_04",text:"Caress"},{id:"act_05",text:"Blow on"},{id:"act_06",text:"Nibble"},{id:"act_07",text:"Lick"},{id:"act_08",text:"Tickle"},{id:"act_09",text:"Stroke"},{id:"act_10",text:"Trace with finger"},{id:"act_11",text:"Breathe on"},{id:"act_12",text:"Press lips to"}],diceBodyParts:[{id:"bp_01",text:"Neck"},{id:"bp_02",text:"Lips"},{id:"bp_03",text:"Ear"},{id:"bp_04",text:"Shoulder"},{id:"bp_05",text:"Back"},{id:"bp_06",text:"Hand"},{id:"bp_07",text:"Inner Wrist"},{id:"bp_08",text:"Collarbone"},{id:"bp_09",text:"Forehead"},{id:"bp_10",text:"Fingertips"},{id:"bp_11",text:"Jawline"},{id:"bp_12",text:"Lower Back"}],thirtySixQuestions:[{id:"q36_01",set:1,order:1,text:"Given the choice of anyone in the world, whom would you want as a dinner guest and why?"},{id:"q36_02",set:1,order:2,text:"Would you like to be famous? In what way would you want to be known?"},{id:"q36_03",set:1,order:3,text:"Before making a phone call, do you ever rehearse what you are going to say? Why or why not?"},{id:"q36_04",set:1,order:4,text:"What would constitute a 'perfect' day for you? Describe it in detail."},{id:"q36_05",set:1,order:5,text:"When did you last sing to yourself? What about to someone else?"},{id:"q36_06",set:1,order:6,text:"If you were able to live to the age of 90 and retain either the mind or body of a 30-year-old for the last 60 years, which would you choose?"},{id:"q36_07",set:1,order:7,text:"Do you have a secret hunch about how you will die?"},{id:"q36_08",set:1,order:8,text:"Name three things you and your partner appear to have in common."},{id:"q36_09",set:1,order:9,text:"For what in your life do you feel most grateful right now?"},{id:"q36_10",set:1,order:10,text:"If you could change anything about the way you were raised, what would it be?"},{id:"q36_11",set:1,order:11,text:"Take four minutes and tell your partner your life story in as much detail as possible."},{id:"q36_12",set:1,order:12,text:"If you could wake up tomorrow having gained one quality or ability, what would it be?"},{id:"q36_13",set:2,order:1,text:"If a crystal ball could tell you the truth about yourself, your life, your future, or anything else, what would you want to know?"},{id:"q36_14",set:2,order:2,text:"Is there something that you have dreamed of doing for a long time? Why have you not done it?"},{id:"q36_15",set:2,order:3,text:"What is the greatest accomplishment of your life so far?"},{id:"q36_16",set:2,order:4,text:"What do you value most in a friendship? How about in your romantic relationship?"},{id:"q36_17",set:2,order:5,text:"What is your most treasured memory with your partner?"},{id:"q36_18",set:2,order:6,text:"What is your most terrible memory? How has it shaped who you are today?"},{id:"q36_19",set:2,order:7,text:"If you knew that in one year you would die suddenly, would you change anything about the way you are living now?"},{id:"q36_20",set:2,order:8,text:"What does love mean to you? Has your definition changed over time?"},{id:"q36_21",set:2,order:9,text:"What roles do affection and physical touch play in your life?"},{id:"q36_22",set:2,order:10,text:"Alternate sharing something you consider a positive characteristic of your partner. Share five items each."},{id:"q36_23",set:2,order:11,text:"How close and warm is your family? Do you feel your childhood was happier than most?"},{id:"q36_24",set:2,order:12,text:"How do you feel about your relationship with your mother? What role has it played in your romantic life?"},{id:"q36_25",set:3,order:1,text:"Make three true 'we' statements each. For instance, 'We are both in this room feeling...'"},{id:"q36_26",set:3,order:2,text:"Complete this sentence: 'I wish I had someone with whom I could share...'"},{id:"q36_27",set:3,order:3,text:"If you were going to become a close friend with your partner, what would be important for them to know about you?"},{id:"q36_28",set:3,order:4,text:"Tell your partner what you like about them. Be very honest, saying things you might not say to someone you have just met."},{id:"q36_29",set:3,order:5,text:"Share an embarrassing moment in your life with your partner."},{id:"q36_30",set:3,order:6,text:"When did you last cry in front of another person? By yourself?"},{id:"q36_31",set:3,order:7,text:"Tell your partner something that you like about them already \u2014 something beyond physical appearance."},{id:"q36_32",set:3,order:8,text:"What, if anything, is too serious to be joked about between you two?"},{id:"q36_33",set:3,order:9,text:"If you were to die this evening with no opportunity to communicate with anyone, what would you most regret not having told someone?"},{id:"q36_34",set:3,order:10,text:"Your house, containing everything you own, catches fire. After saving your loved ones and pets, you have time to safely make one final dash. What would you save?"},{id:"q36_35",set:3,order:11,text:"Of all the people in your family, whose death would you find most disturbing? Why?"},{id:"q36_36",set:3,order:12,text:"Share a personal problem and ask your partner's advice on how they might handle it. Also, ask them to reflect back to you how you seem to be feeling about the problem."}],moodCards:[{id:"mood_01",label:"Playful",emoji:"\ud83d\ude1c",color:"#FF6B6B"},{id:"mood_02",label:"Romantic",emoji:"\ud83c\udf39",color:"#E94560"},{id:"mood_03",label:"Adventurous",emoji:"\ud83d\uddfa\ufe0f",color:"#FF9800"},{id:"mood_04",label:"Tender",emoji:"\ud83e\udd17",color:"#FFB6C1"},{id:"mood_05",label:"Passionate",emoji:"\ud83d\udd25",color:"#D32F2F"},{id:"mood_06",label:"Curious",emoji:"\ud83e\uddd0",color:"#9C27B0"},{id:"mood_07",label:"Relaxed",emoji:"\ud83d\ude0c",color:"#4CAF50"},{id:"mood_08",label:"Energetic",emoji:"\u26a1",color:"#FFC107"},{id:"mood_09",label:"Sensual",emoji:"\u2728",color:"#E91E63"},{id:"mood_10",label:"Connected",emoji:"\ud83d\udc95",color:"#F48FB1"},{id:"mood_11",label:"Daring",emoji:"\ud83d\udcaa",color:"#FF5722"},{id:"mood_12",label:"Gentle",emoji:"\ud83d\udd4a\ufe0f",color:"#81D4FA"},{id:"mood_13",label:"Spontaneous",emoji:"\ud83c\udfb2",color:"#FF7043"},{id:"mood_14",label:"Intimate",emoji:"\ud83d\udc8b",color:"#C62828"},{id:"mood_15",label:"Grateful",emoji:"\ud83d\ude4f",color:"#66BB6A"},{id:"mood_16",label:"Confident",emoji:"\ud83d\ude0e",color:"#42A5F5"},{id:"mood_17",label:"Vulnerable",emoji:"\ud83e\udd7a",color:"#CE93D8"},{id:"mood_18",label:"Flirty",emoji:"\ud83d\ude0f",color:"#EC407A"},{id:"mood_19",label:"Dreamy",emoji:"\u2601\ufe0f",color:"#B39DDB"},{id:"mood_20",label:"Wild",emoji:"\ud83d\udc06",color:"#E65100"},{id:"mood_21",label:"Cozy",emoji:"\ud83e\uddf8",color:"#A1887F"},{id:"mood_22",label:"Mysterious",emoji:"\ud83c\udf19",color:"#5C6BC0"},{id:"mood_23",label:"Devoted",emoji:"\ud83d\udc9d",color:"#AD1457"},{id:"mood_24",label:"Free-spirited",emoji:"\ud83e\udd8b",color:"#26A69A"}]}},1176,[]);
