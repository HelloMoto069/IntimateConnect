rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own document and subcollections
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Couples: both partners can read/write
    match /couples/{coupleId}/{document=**} {
      allow read, write: if request.auth != null && (
        resource.data.partnerA == request.auth.uid ||
        resource.data.partnerB == request.auth.uid
      );
    }

    // Content: read-only for authenticated users
    match /content/{document=**} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // App config: read-only for everyone
    match /appConfig/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
